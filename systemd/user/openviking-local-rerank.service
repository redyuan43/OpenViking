[Unit]
Description=OpenViking Local GPU Rerank Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/nx/github/OpenViking
Environment=LOCAL_RERANK_DEVICE=auto
ExecStart=/home/nx/github/OpenViking/scripts/run_local_rerank_service.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
